# ── Server ──────────────────────────────────────────────────────────────────
# Mode: "server" (default) starts the HTTP MCP server.
#       "reindex" runs the crawler + embedder once and exits.
MODE=server
PORT=3000
LOG_LEVEL=info

# ── Azure: PostgreSQL ───────────────────────────────────────────────────────
# Fully-qualified hostname of the Postgres Flexible Server.
POSTGRES_HOST=glmcp-pg.postgres.database.azure.com
POSTGRES_DB=gospel
# When the app runs inside Azure Container Apps:
#   POSTGRES_USER = the Managed Identity's principal name (set by Bicep).
# When you run admin scripts from your laptop:
#   POSTGRES_USER = your Entra UPN (you@yourtenant.onmicrosoft.com)
POSTGRES_USER=
POSTGRES_PORT=5432
POSTGRES_SSL=true

# ── Azure: OpenAI ───────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://glmcp-openai.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Azure: Managed Identity ─────────────────────────────────────────────────
# The clientId of the User-Assigned Managed Identity attached to the
# Container App. DefaultAzureCredential reads this to scope to the right MI
# when multiple are attached. Leave blank for local dev (uses az login).
AZURE_CLIENT_ID=

# ── Caching ─────────────────────────────────────────────────────────────────
ARTICLE_CACHE_MAX_ITEMS=500
ARTICLE_CACHE_TTL_MS=900000

# Cache for API key lookups (so we don't hit Postgres on every request).
KEY_CACHE_TTL_MS=60000

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_IP=60
RATE_LIMIT_WINDOW=1 minute
